/*C3*/SET SCHEMA PUBLIC
drop table CLIENTE if exists
drop table PEDIDO_DE_PLACA if exists
drop table SERVICO if exists
drop sequence hibernate_sequence if exists
create sequence hibernate_sequence start with 1 increment by 1
create table CLIENTE (CLIENTE_IDENTIFICADOR bigint not null, CLIENTE_CPF_CNPJ varchar(14), CLIENTE_EMAIL varchar(70), CLIENTE_NOME varchar(50), CLIENTE_TELEFONE varchar(50), primary key (CLIENTE_IDENTIFICADOR))
create table PEDIDO_DE_PLACA (PEDIDO_DE_PLACA_ID bigint not null, PEDIDO_DE_PLACA_COR_PLACA varchar(50), PEDIDO_DE_PLACA_CPF_CNPJ_PROPRIETARIO varchar(18), PEDIDO_DE_PLACA_DATA TIMESTAMP, PEDIDO_DE_PLACA_PLACA_VEICULO varchar(7), PEDIDO_DE_PLACA_QUANTIDADE integer, PEDIDO_DE_PLACA_RENAVAM varchar(50), PEDIDO_DE_PLACA_TIPO_PLACA varchar(50), primary key (PEDIDO_DE_PLACA_ID))
create table SERVICO (SERVICO_ID bigint not null, SERVICO_CPF_CNPJ_CLIENTE varchar(18), SERVICO_DATA date, SERVICO_DESCRICAO varchar(50), SERVICO_NOME_CLIENTE varchar(50), SERVICO_PLACA_VEICULO varchar(7), SERVICO_TELEFONE_CLIENTE varchar(50), SERVICO_VALOR float, primary key (SERVICO_ID))
create index INDEX_NOME on CLIENTE (CLIENTE_NOME)
alter table CLIENTE add constraint INDEX_CLIENTE_CPF_CNPJ unique (CLIENTE_CPF_CNPJ)
INSERT INTO CLIENTE VALUES(1,'2','3','1','4')
ALTER SEQUENCE PUBLIC.HIBERNATE_SEQUENCE RESTART WITH 2
COMMIT
